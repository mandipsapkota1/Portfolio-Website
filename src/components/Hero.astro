<section id="home" class="home">

  <!-- Background image -->
  <img
    class="hero-bg"
    src="/bg.svg"
    alt=""
    aria-hidden="true"
    loading="eager"
    decoding="async"
  />
  <div class="hero-bg-scrim" aria-hidden="true"></div>

  <!-- Animated particle dot grid -->
  <canvas id="hero-canvas" aria-hidden="true"></canvas>

  <!-- Radial ambient glow -->
  <div class="bg-glow" aria-hidden="true"></div>

  <div class="hero-center">

    <!-- Badge -->
    <div class="avail-badge hero-name-1">
      <span class="green-dot"></span> Available for work
    </div>

    <!-- Circular photo with spinning ring -->
    <div class="photo-ring hero-name-2" role="img" aria-label="Mandip Sapkota">
      <div class="ring-track" aria-hidden="true"></div>
      <div class="ring-glow"  aria-hidden="true"></div>
      <img src="/images/DP.jpeg" alt="Mandip Sapkota" />
    </div>

    <!-- Name -->
    <h1 class="hero-role">
      <span class="name-white">Mandip</span>
      <span class="name-yellow">Sapkota</span>
    </h1>

    <!-- Typed role with decorative lines -->
    <p class="role-line hero-bio">
      <span class="deco-line" aria-hidden="true"></span>
      I'm a <span id="typed"></span><span class="caret">|</span>
      <span class="deco-line" aria-hidden="true"></span>
    </p>

    <!-- Bio -->
    <p class="home-bio hero-btns">
      I build fast, functional websites and Android apps — from PHP backends
      to pixel-perfect frontends. Six languages, three years in,
      and still writing cleaner code every week.
    </p>

    <!-- Stat pills -->
    <div class="stat-pills hero-social">
      <div class="stat-pill">
        <strong>20+</strong><span>Projects</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat-pill">
        <strong>3+</strong><span>Years Exp.</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat-pill">
        <strong>6+</strong><span>Technologies</span>
      </div>
    </div>

    <!-- CTAs -->
    <div class="home-btns hero-btns" style="justify-content:center">
      <a href="#contact"  class="btn-solid">Start a Project &rarr;</a>
      <a href="#projects" class="btn-outline">See My Work</a>
      <a href="/cv/Mandip-Sapkota-CV.pdf" download="Mandip-Sapkota-CV.pdf" class="btn-cv">
        <i class="bx bx-download"></i> Download CV
      </a>
    </div>

    <!-- Socials -->
    <div class="socials hero-social" style="justify-content:center">
      <a href="https://www.facebook.com/mandip.sapkota123" aria-label="Facebook" target="_blank" rel="noopener">
        <i class="bx bxl-facebook"></i>
      </a>
      <a href="https://www.linkedin.com/in/mandip-sapkota-86578937a/" aria-label="LinkedIn" target="_blank" rel="noopener">
        <i class="bx bxl-linkedin"></i>
      </a>
      <a href="https://github.com/mandipsapkota1" aria-label="GitHub" target="_blank" rel="noopener">
        <i class="bx bxl-github"></i>
      </a>
    </div>

  </div>

  <!-- Scroll cue -->
  <div class="scroll-cue" aria-hidden="true">
    <span></span>
  </div>
</section>

<!-- Canvas particle script -->
<script>
const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
if (canvas) {
  const ctx = canvas.getContext('2d');
  if (ctx) {
    const spacing = 38;
    let dots: { x: number; y: number; bx: number; by: number }[] = [];
    let mouseX = -999, mouseY = -999;

    function buildDots() {
      dots = [];
      for (let x = 0; x < canvas!.width; x += spacing) {
        for (let y = 0; y < canvas!.height; y += spacing) {
          dots.push({ x, y, bx: x, by: y });
        }
      }
    }

    function resize() {
      canvas!.width  = window.innerWidth;
      canvas!.height = window.innerHeight;
      buildDots();
    }
    resize();
    window.addEventListener('resize', resize, { passive: true });

    document.addEventListener('mousemove', e => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    });

    function draw() {
      ctx!.clearRect(0, 0, canvas!.width, canvas!.height);
      const maxD = 130;
      for (const dot of dots) {
        const dx   = mouseX - dot.bx;
        const dy   = mouseY - dot.by;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const t    = dist < maxD ? 1 - dist / maxD : 0;
        dot.x += ((dot.bx - dx * t * 0.28) - dot.x) * 0.1;
        dot.y += ((dot.by - dy * t * 0.28) - dot.y) * 0.1;
        ctx!.beginPath();
        ctx!.arc(dot.x, dot.y, 1.1, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(232,255,72,${0.055 + t * 0.18})`;
        ctx!.fill();
      }
      requestAnimationFrame(draw);
    }
    draw();
  }
}
</script>

<style>
/* ─── SECTION ─── */
.home {
  min-height: 100vh;
  padding: var(--hh) 8% 6rem;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  position: relative; overflow: hidden;
  text-align: center;
}

/* Background image */
.hero-bg {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  opacity: 1;
  z-index: 0;
  pointer-events: none;
  user-select: none;
}
/* Bottom fade so the hero blends into the next section */
.hero-bg-scrim {
  position: absolute; inset: 0;
  background:
    linear-gradient(to bottom, transparent 0%, transparent 62%, rgba(7,9,15,.7) 86%, var(--bg) 100%);
  z-index: 0;
  pointer-events: none;
}

/* Canvas */
#hero-canvas {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  pointer-events: none; z-index: 1;
}

/* Ambient glow */
.bg-glow {
  position: absolute; top: 30%; left: 50%;
  transform: translate(-50%, -50%);
  width: 700px; height: 700px; border-radius: 50%;
  background: radial-gradient(circle, rgba(232,255,72,.07) 0%, transparent 65%);
  animation: glowPulse 7s ease-in-out infinite;
  pointer-events: none; z-index: 2;
}

/* Content wrapper */
.hero-center {
  position: relative; z-index: 3;
  display: flex; flex-direction: column;
  align-items: center; gap: 2rem;
  max-width: 72rem;
}

/* Badge */
.avail-badge {
  display: inline-flex; align-items: center; gap: .8rem;
  border: 1px solid var(--glass-border);
  background: var(--glass); backdrop-filter: blur(12px);
  border-radius: 50px; padding: .6rem 1.4rem;
  font-size: 1.3rem; color: var(--muted);
}
.green-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: #22c55e; box-shadow: 0 0 0 3px rgba(34,197,94,.22);
  animation: gpulse 2s ease infinite; flex-shrink: 0;
}

/* ─── CIRCULAR PHOTO RING ─── */
.photo-ring {
  position: relative;
  width: 180px; height: 180px;
}

/* Spinning yellow conic ring (21st.dev spin-around technique) */
.ring-track {
  position: absolute; inset: -3px; border-radius: 50%;
  background: conic-gradient(
    from 0deg,
    var(--yellow) 0deg,
    transparent 80deg,
    transparent 280deg,
    var(--yellow) 360deg
  );
  animation: spin-slow 4s linear infinite;
  z-index: 0;
}
/* Soft glow behind ring */
.ring-glow {
  position: absolute; inset: -12px; border-radius: 50%;
  background: radial-gradient(circle, rgba(232,255,72,.18) 0%, transparent 70%);
  animation: glowPulse 4s ease-in-out infinite;
  z-index: 0;
}
.photo-ring img {
  position: absolute; inset: 3px;
  width: calc(100% - 6px); height: calc(100% - 6px);
  object-fit: cover; border-radius: 50%;
  z-index: 1;
  /* Dark mask between ring and photo */
  box-shadow: 0 0 0 3px var(--bg);
}

@keyframes spin-slow {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* ─── NAME ─── */
.hero-center h1 {
  font-family: var(--fhead);
  font-size: clamp(4.8rem, 9vw, 9.6rem);
  font-weight: 800; line-height: .95; letter-spacing: -.04em;
  display: flex; gap: .35em; flex-wrap: wrap; justify-content: center;
  margin: 0;
}
.name-white  { color: var(--text); }
.name-yellow { color: var(--yellow); }

/* ─── TYPED ROLE ROW ─── */
.role-line {
  display: flex; align-items: center; gap: 1.4rem;
  font-size: 1.75rem; color: var(--muted);
  margin: 0;
}
.deco-line {
  display: block; height: 1px; width: 48px;
  background: linear-gradient(90deg, transparent, var(--yellow));
  flex-shrink: 0;
}
.deco-line:last-child {
  background: linear-gradient(90deg, var(--yellow), transparent);
}
#typed { color: var(--text); font-weight: 500; }
.caret { color: var(--yellow); animation: blink 1s step-end infinite; }

/* ─── BIO ─── */
.home-bio {
  font-size: 1.6rem; color: var(--muted);
  max-width: 50rem; line-height: 1.75; margin: 0;
}

/* ─── STAT PILLS ─── */
.stat-pills {
  display: flex; align-items: center; gap: 2rem;
  background: var(--glass); backdrop-filter: blur(12px);
  border: 1px solid var(--glass-border);
  border-radius: 50px; padding: 1rem 2.4rem;
}
.stat-pill { text-align: center; }
.stat-pill strong {
  display: block; font-family: var(--fhead);
  font-size: 2rem; font-weight: 700;
  color: var(--yellow); line-height: 1;
}
.stat-pill span { font-size: 1.2rem; color: var(--muted); }
.stat-divider {
  width: 1px; height: 32px;
  background: var(--border);
}

/* ─── CTAs ─── */
.home-btns { display: flex; gap: 1.2rem; flex-wrap: wrap; margin: 0; }

/* ─── SCROLL CUE ─── */
.scroll-cue {
  position: absolute; bottom: 2.4rem; left: 50%;
  transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center;
  animation: heroFadeUp .6s ease .9s both;
}
.scroll-cue span {
  display: block; width: 1px; height: 52px;
  background: linear-gradient(to bottom, var(--yellow), transparent);
  animation: scrollPulse 1.8s ease-in-out infinite;
}
@keyframes scrollPulse {
  0%, 100% { opacity: .2; transform: scaleY(1); }
  50%       { opacity: .8; transform: scaleY(1.15); }
}

/* ─── RESPONSIVE ─── */
@media (max-width: 768px) {
  .home { padding: calc(var(--hh) + 2rem) 5% 5rem; }
  .hero-center { gap: 1.6rem; }
  .stat-pills { gap: 1.4rem; padding: .9rem 1.6rem; }
  .role-line { font-size: 1.55rem; }
  .deco-line { width: 28px; }
  .home-btns { justify-content: center !important; }
}
@media (max-width: 500px) {
  .stat-pills { flex-wrap: wrap; border-radius: 1.4rem; justify-content: center; }
  .stat-divider { display: none; }
  .home-btns { flex-direction: column; align-items: center; }
}
</style>
